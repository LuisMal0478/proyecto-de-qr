# Configuración del Servidor
PORT=5000
NODE_ENV=development

# Base de Datos MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/qrify

# Autenticación
JWT_SECRET=tu_clave_secreta_super_segura_aqui_12345

# Origen Permitido para CORS (Frontend)
CLIENT_URL=http://localhost:5173

# ePayco Credentials (sandbox o producción)
EPAYCO_PUBLIC_KEY=tu_public_key_epayco
EPAYCO_PRIVATE_KEY=tu_private_key_epayco

# Configuración de Correo SMTP (Producción)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=tu_usuario_smtp
SMTP_PASS=tu_contrasena_smtp
SMTP_FROM="QRify Notifications <noreply@qrify.com>"
